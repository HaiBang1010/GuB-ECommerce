# GuB frontend (Next.js) — environment template.
# Copy to .env.local and fill in real values. NEVER commit real values.
# Vercel: set these in the project dashboard.
#
# ONLY NEXT_PUBLIC_* vars are exposed to the browser. NEVER put secrets here:
# no DATABASE_URL, no Stripe secret key, no Supabase service-role key — those
# live only in the backend (see backend/.env.example).

# ─── Backend API ───────────────────────────────────────────────
# Base URL of the NestJS backend (Render/Koyeb). Local dev: http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Supabase (browser auth client) ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
# Anon/public key — safe to expose to the browser by design.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Stripe (publishable key only — Stripe.js / Elements) ─────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

