# ─── Dependencies ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/versions

# ─── Environment (never commit real secrets) ───────────────────
.env
.env.*
!.env.example
# Keep the template, ignore real values:
*.local

# ─── Build / cache ─────────────────────────────────────────────
dist/
build/
out/
.next/
.turbo/
.cache/
*.tsbuildinfo

# ─── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Test / coverage ───────────────────────────────────────────
coverage/
.nyc_output/

# ─── Deploy platforms ──────────────────────────────────────────
.vercel/

# ─── Claude Code (commit shared config, ignore local overrides) ─
.claude/settings.local.json

# ─── Editors / OS ──────────────────────────────────────────────
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
*.pem
