{
  "name": "gub",
  "version": "0.1.0",
  "private": true,
  "description": "GuB — modular monolith shoes & clothing web store (portfolio, $0 free tier)",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace frontend",
