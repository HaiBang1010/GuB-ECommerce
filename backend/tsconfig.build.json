{
  "extends": "./tsconfig.json",
  // Keep the incremental cache INSIDE dist so nest-cli's deleteOutDir wipes it
  // together with the emitted JS. Otherwise a stale tsbuildinfo (outside dist)
  // makes tsc skip re-emitting .js after dist is deleted → MODULE_NOT_FOUND.
  "compilerOptions": {
    "tsBuildInfoFile": "./dist/tsconfig.build.tsbuildinfo"
  },
  "exclude": ["node_modules", "test", "dist", "**/*.spec.ts"]
}
