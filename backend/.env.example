# GuB backend (NestJS) — environment template.
# Copy to .env and fill in real values. NEVER commit the real .env.
# Render/Koyeb: set these in the service dashboard. Stripe stays in TEST mode in dev.

# ─── Server ────────────────────────────────────────────────────
# Render injects PORT automatically; falls back to 3001 locally.
PORT=3001

# ─── Database (Neon Postgres) — backend only ──────────────────
# Pooled Neon connection string. The browser must NEVER see this.
DATABASE_URL=

# ─── Supabase (JWT verification · Storage · Realtime) ─────────
SUPABASE_URL=
# Service-role key — full admin access, backend only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe (test mode) — secret side, backend only ───────────
# Secret API key (sk_test_...).
STRIPE_TEST_KEY=
# Webhook signing secret (whsec_...) — verifies incoming Stripe webhooks.
STRIPE_WEBHOOK_SECRET=

# ─── Upstash QStash (notification queue producer) ─────────────
UPSTASH_QSTASH_TOKEN=

# ─── Resend (transactional email) ─────────────────────────────
RESEND_API_KEY=

# ─── Admin / cron ──────────────────────────────────────────────
# Shared secret required in the header of /admin/jobs/* (cron callers).
ADMIN_JOB_SECRET=
ADMIN_API_SECRET=

# ─── Cloudinary (image hosting) — secret side, backend only ─────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=   

## ─── Supabase (JWT verification · Storage · Realtime) ─────────
SUPABASE_URL=

# ─── Stripe (test mode) — secret side, backend only ───────────
STRIPE_SECRET_KEY=sk_test_....
STRIPE_WEBHOOK_SECRET=whsec_...